{
  "name": "@stylescan/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/clerk-auth": "^2.0.0",
    "@hono/node-server": "^1.13.0",
    "@stylescan/schema": "workspace:*",
    "@stylescan/types": "workspace:*",
    "bullmq": "^5.30.0",
    "dotenv": "^17.4.2",
    "hono": "^4.7.0",
    "ioredis": "^5.4.0",
    "jose": "^6.2.2",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@stylescan/tsconfig": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
